{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "dev",
      "inherits": "base",
      "displayName": "Host Unit Tests",
      "description": "Host x86_64 test build that uses mock fixtures only for local unit tests.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_TESTS": "ON",
        "ENABLE_MOCK_SOURCES": "ON",
        "ENABLE_DEV_WARNINGS": "ON",
        "ENABLE_DEV_LOGGING": "ON",
        "ENABLE_SANITIZERS": "OFF",
        "ENABLE_ASCENDCL": "OFF",
        "ENABLE_OPENCV_PREPROCESSOR": "ON",
        "ENABLE_OPENCV_POSTPROCESSOR": "ON",
        "SENTINEL_DEFAULT_CONFIG_DIR": "tests/fixtures/mock_config"
      }
    },
    {
      "name": "asan",
      "inherits": "dev",
      "displayName": "Development (ASan/UBSan)",
      "description": "Debug build with sanitizers enabled for memory and UB checks.",
      "cacheVariables": {
        "ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "board-debug",
      "inherits": "base",
      "displayName": "Board Debug Deployment",
      "description": "Host-side cross-compiled aarch64 debug build for deploying to the development board.",
      "toolchainFile": "${sourceDir}/cmake/toolchains/aarch64-linux-gnu.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/board-debug-package",
        "ENABLE_TESTS": "OFF",
        "ENABLE_MOCK_SOURCES": "OFF",
        "ENABLE_DEV_WARNINGS": "ON",
        "ENABLE_DEV_LOGGING": "ON",
        "ENABLE_SANITIZERS": "OFF",
        "ENABLE_ASCENDCL": "ON",
        "ENABLE_OPENCV_PREPROCESSOR": "ON",
        "ENABLE_OPENCV_POSTPROCESSOR": "ON",
        "INSTALL_DEBUG_SOURCE": "ON",
        "ASCENDCL_LIB_DIR": "${sourceDir}/third_party/ascend-cann/8.0.0/devlib/linux/aarch64",
        "SENTINEL_DEFAULT_CONFIG_DIR": "config/dev"
      }
    },
    {
      "name": "board-native-debug",
      "inherits": "base",
      "displayName": "Board Native Debug",
      "description": "Native aarch64 debug build on the development board with the board-installed Ascend Toolkit.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/board-native-debug-package",
        "ENABLE_TESTS": "OFF",
        "ENABLE_MOCK_SOURCES": "OFF",
        "ENABLE_DEV_WARNINGS": "ON",
        "ENABLE_DEV_LOGGING": "ON",
        "ENABLE_SANITIZERS": "OFF",
        "ENABLE_ASCENDCL": "ON",
        "ENABLE_OPENCV_PREPROCESSOR": "ON",
        "ENABLE_OPENCV_POSTPROCESSOR": "ON",
        "INSTALL_DEBUG_SOURCE": "OFF",
        "ASCENDCL_ROOT": "/usr/local/Ascend/ascend-toolkit/8.0.0/aarch64-linux",
        "SENTINEL_DEFAULT_CONFIG_DIR": "config/dev"
      }
    },
    {
      "name": "prod",
      "inherits": "base",
      "displayName": "Production Deployment",
      "description": "Host-side cross-compiled aarch64 release build for deployment to the board.",
      "toolchainFile": "${sourceDir}/cmake/toolchains/aarch64-linux-gnu.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/prod-package",
        "ENABLE_TESTS": "OFF",
        "ENABLE_MOCK_SOURCES": "OFF",
        "ENABLE_DEV_WARNINGS": "ON",
        "ENABLE_DEV_LOGGING": "OFF",
        "ENABLE_SANITIZERS": "OFF",
        "ENABLE_ASCENDCL": "ON",
        "ENABLE_OPENCV_PREPROCESSOR": "ON",
        "ENABLE_OPENCV_POSTPROCESSOR": "ON",
        "INSTALL_DEBUG_SOURCE": "OFF",
        "ASCENDCL_LIB_DIR": "${sourceDir}/third_party/ascend-cann/8.0.0/devlib/linux/aarch64",
        "SENTINEL_DEFAULT_CONFIG_DIR": "config/prod"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "board-debug",
      "configurePreset": "board-debug"
    },
    {
      "name": "board-native-debug",
      "configurePreset": "board-native-debug"
    },
    {
      "name": "prod",
      "configurePreset": "prod"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
